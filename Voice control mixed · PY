# ─────────────────────────────────────────
#  SETUP
# ─────────────────────────────────────────
recognizer = sr.Recognizer()
engine = pyttsx3.init()
engine.setProperty('rate', 160)
engine.setProperty('volume', 1.0)

# Language priority order for recognition
# te-IN = Telugu, hi-IN = Hindi, en-IN = English (India)
LANGUAGES = ["te-IN", "hi-IN", "en-IN", "en-US"]

def speak(text):
    """Speak response in English."""
    print(f"🤖 Assistant: {text}")
    engine.say(text)
    engine.runAndWait()

def listen():
    """
    Try recognizing speech in Telugu, Hindi, and English.
    Returns the recognized text (lowercased) or empty string.
    """
    with sr.Microphone() as source:
        print("\n🎤 Listening... (Telugu / Hindi / English lo matladandi)")
        recognizer.adjust_for_ambient_noise(source, duration=0.5)
        try:
            audio = recognizer.listen(source, timeout=6, phrase_time_limit=10)
        except sr.WaitTimeoutError:
            print("⏱️ No speech detected.")
            return ""

    # Try each language until one succeeds
    for lang in LANGUAGES:
        try:
            command = recognizer.recognize_google(audio, language=lang).lower()
            print(f"✅ Recognized [{lang}]: {command}")
            return command
        except sr.UnknownValueError:
            continue
        except sr.RequestError:
            speak("Internet connection issue. Please check your connection.")
            return ""

    print("❓ Could not understand in any language.")
    return ""

