# ─────────────────────────────────────────
#  MAIN LOOP
# ─────────────────────────────────────────
def process_command(command):
    if not command:
        return

    handlers = [
        handle_exit,
        handle_help,
        handle_system,
        handle_volume,
        handle_screenshot,
        handle_type,
        handle_youtube,
        handle_search,
        handle_open_website,
        handle_open_app,
    ]

    for handler in handlers:
        if handler(command):
            return

    speak(f"Sorry, I didn't understand that. Say help to see all commands.")

def main():
    print("=" * 65)
    print("   🎙️  MIXED LANGUAGE VOICE CONTROL  (Telugu + Hindi + English)")
    print("=" * 65)
    show_help()
    speak("Voice control active. You can speak in Telugu, Hindi, or English!")

    while True:
        command = listen()
        if command:
            process_command(command)

if __name__ == "__main__":
    main()
