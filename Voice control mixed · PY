#  COMMAND HANDLERS
# ─────────────────────────────────────────

def contains_any(command, keywords):
    return any(kw in command for kw in keywords)

def handle_exit(command):
    if contains_any(command, EXIT_KEYWORDS):
        speak("Okay! Voice control stopped. Bye bye!")
        sys.exit(0)
    return False

def handle_help(command):
    if contains_any(command, HELP_KEYWORDS):
        show_help()
        speak("Here are all your available commands.")
        return True
    return False

def handle_open_app(command):
    for keyword, app_key in APP_KEYWORDS.items():
        if keyword in command:
            app_path = APP_PATHS.get(app_key, "")
            if app_path:
                speak(f"Opening {app_key}")
                try:
                    os.startfile(os.path.expandvars(app_path))
                except Exception:
                    subprocess.Popen(app_path, shell=True)
                return True
    return False

def handle_open_website(command):
    # Check for "open <site>" pattern
    for trigger in OPEN_KEYWORDS:
        if trigger in command:
            for site, url in WEBSITE_MAP.items():
                if site in command:
                    speak(f"Opening {site}")
                    webbrowser.open(url)
                    return True
    return False

def handle_search(command):
    if contains_any(command, SEARCH_KEYWORDS) and not contains_any(command, YOUTUBE_KEYWORDS):
        # Extract query by removing search keywords
        query = command
        for kw in SEARCH_KEYWORDS:
            query = query.replace(kw, "")
        query = query.replace("for", "").replace("lo", "").replace("kosam", "").strip()
        if query:
            speak(f"Searching Google for {query}")
            webbrowser.open(f"https://www.google.com/search?q={query}")
        else:
            speak("What would you like to search for?")
        return True
    return False

def handle_youtube(command):
    if contains_any(command, YOUTUBE_KEYWORDS):
        query = command
        for kw in YOUTUBE_KEYWORDS + ["search", "play", "chupinchu", "lo"]:
            query = query.replace(kw, "")
        query = query.strip()
        if query:
            speak(f"Searching YouTube for {query}")
            webbrowser.open(f"https://www.youtube.com/results?search_query={query}")
        else:
            speak("Opening YouTube")
            webbrowser.open("https://www.youtube.com")
        return True
    return False

def handle_volume(command):
    if contains_any(command, VOLUME_UP_KEYWORDS):
        for _ in range(5): pyautogui.press("volumeup")
        speak("Volume increased")
        return True
    if contains_any(command, VOLUME_DOWN_KEYWORDS):
        for _ in range(5): pyautogui.press("volumedown")
        speak("Volume decreased")
        return True
    if contains_any(command, MUTE_KEYWORDS):
        pyautogui.press("volumemute")
        speak("Toggled mute")
        return True
    return False

def handle_screenshot(command):
    if contains_any(command, SCREENSHOT_KEYWORDS):
        speak("Taking a screenshot")
        pyautogui.hotkey("win", "prtsc")
        speak("Screenshot saved to your Pictures folder")
        return True
    return False

def handle_type(command):
    if command.startswith("type "):
        text = command.replace("type ", "", 1)
        speak(f"Typing: {text}")
        time.sleep(0.5)
        pyautogui.typewrite(text, interval=0.05)
        return True
    return False

def handle_system(command):
    if contains_any(command, SHUTDOWN_KEYWORDS):
        speak("Shutting down the computer in 10 seconds. Say cancel to stop.")
        os.system("shutdown /s /t 10")
        return True
    if contains_any(command, RESTART_KEYWORDS):
        speak("Restarting the computer in 10 seconds.")
        os.system("shutdown /r /t 10")
        return True
    if contains_any(command, CANCEL_KEYWORDS):
        os.system("shutdown /a")
        speak("Shutdown cancelled.")
        return True
    if contains_any(command, LOCK_KEYWORDS):
        speak("Locking the screen")
        os.system("rundll32.exe user32.dll,LockWorkStation")
        return True
    if contains_any(command, SLEEP_KEYWORDS):
        speak("Putting the computer to sleep")
        os.system("rundll32.exe powrprof.dll,SetSuspendState 0,1,0")
        return True
    return False

